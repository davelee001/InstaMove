PAYMENT_RATE_LIMIT=10
ADMIN_RATE_LIMIT=30
RATE_LIMIT_WINDOW_MS=60000
LND_REQUEST_TIMEOUT_MS=5000
LND_MAX_RESPONSE_BYTES=1048576
LND_GET_RETRY_ATTEMPTS=3
LND_RETRY_DELAY_MS=150
